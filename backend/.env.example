# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Frontend
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=
FRONTEND_ORIGIN_REGEX=

# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# LLM
GOOGLE_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key

# Bhashini
BHASHINI_API_KEY=your-bhashini-key
BHASHINI_USER_ID=your-bhashini-user-id

# App
ENVIRONMENT=development

# SIP / Twilio (for outbound phone calls via LiveKit)
SIP_TRUNK_URI=sip:xxxxx.pstn.twilio.com
SIP_TRUNK_USERNAME=
SIP_TRUNK_PASSWORD=
SIP_TRUNK_CALLER_ID=+91XXXXXXXXXX
SIP_TRUNK_ID=  # filled after running POST /api/voice/sip/setup
